{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "#": ["entrypoints/"],
      "#/*": ["./entrypoints/*"],
      "~": ["."],
      "~/*": ["./*"],
      "##": ["./*"],
      "##/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"]
    }
  },
  "include": ["./**/*", "./.wxt/wxt.d.ts"],
  "exclude": [
    "./.output",
    "./node_modules/",
    "./wxt.config.ts",
    "./entrypoints/types/*"
  ]
}
